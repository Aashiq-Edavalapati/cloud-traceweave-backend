# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Supabase)
# Connection pooling (used at runtime)
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_POOL_HOST>:6543/<DB_NAME>?pgbouncer=true"
# Direct connection (used for migrations)
DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>"

# MongoDB
MONGO_URL="mongodb://<MONGO_HOST>:27017/<MONGO_DB_NAME>"

# JWT
JWT_SECRET="<JWT_SECRET_KEY>"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="<GOOGLE_CLIENT_ID>"
GOOGLE_CLIENT_SECRET="<GOOGLE_CLIENT_SECRET>"
GOOGLE_CALLBACK_URL="http://localhost/api/v1/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID="<GITHUB_CLIENT_ID>"
GITHUB_CLIENT_SECRET="<GITHUB_CLIENT_SECRET>"
GITHUB_CALLBACK_URL="http://localhost/api/v1/auth/github/callback"

# Frontend
CLIENT_URL="http://localhost:3000"

# Email (SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="<EMAIL_ADDRESS>"
EMAIL_PASS="<EMAIL_APP_PASSWORD>"
EMAIL_FROM="Traceweave Support <no-reply@traceweave.com>"
