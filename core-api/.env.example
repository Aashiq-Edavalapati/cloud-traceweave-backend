# Server port and env
PORT=4000
NODE_ENV=<your_env_mode>

# PostgreSQL (Supabase)
# Connection pooling (used at runtime)
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_POOL_HOST>:6543/<DB_NAME>?pgbouncer=true"
# Direct connection (used for migrations)
DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>"

# MongoDB
MONGO_URI="mongodb://<MONGO_HOST>:27017/<MONGO_DB_NAME>/?authSource=admin&retryWrites=true&w=majority"

# JWT
JWT_SECRET="<JWT_SECRET_KEY>"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="<GOOGLE_CLIENT_ID>"
GOOGLE_CLIENT_SECRET="<GOOGLE_CLIENT_SECRET>"
GOOGLE_CALLBACK_URL="http://localhost/api/v1/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID="<GITHUB_CLIENT_ID>"
GITHUB_CLIENT_SECRET="<GITHUB_CLIENT_SECRET>"
GITHUB_CALLBACK_URL="http://localhost/api/v1/auth/github/callback"

# Frontend
CLIENT_URL="http://localhost:3000"

# Email (SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="<EMAIL_ADDRESS>"
EMAIL_PASS="<EMAIL_APP_PASSWORD>"
EMAIL_FROM="Traceweave Support <no-reply@traceweave.com>"

# Azure Storage (for file uploads)
# Option 1: Using Connection String (permanent access - recommended for production)
# Get your connection string from Azure Portal > Storage Account > Access Keys
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<your_account_name>;AccountKey=<your_account_key>;EndpointSuffix=core.windows.net"

# Option 2: Using SAS Token (temporary access - good for testing)
# Generate SAS in Azure Portal > Storage Account > Container > Generate SAS
# AZURE_STORAGE_ACCOUNT_NAME="<your_storage_account>"
# AZURE_STORAGE_CONTAINER_NAME="uploads"
# AZURE_STORAGE_SAS_TOKEN="sp=racwdli&st=....&sig=...."

# Azure Service Bus (for replay request events)
SERVICE_BUS_ENABLED=true
SERVICE_BUS_CONNECTION_STRING="Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=<policy-name>;SharedAccessKey=<key>"
SERVICE_BUS_QUEUE_NAME="replay-requests"
