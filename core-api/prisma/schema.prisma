generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  fullName               String?               @map("full_name")
  avatarUrl              String?               @map("avatar_url")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  deletedAt              DateTime?             @map("deleted_at")
  createdVariables       EnvironmentVariable[]
  createdEnvironments    Environment[]
  identities             Identity[]
  accessibleEnvironments UserEnvironment[]
  workspaces             WorkspaceMember[]
  ownedWorkspaces        Workspace[]

  @@map("users")
}

model Identity {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  provider     String
  providerId   String?  @map("provider_id")
  passwordHash String?  @map("password_hash")
  accessToken  String?  @map("access_token")
  refreshToken String?  @map("refresh_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@map("identities")
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  description      String?
  ownerId          String            @map("owner_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  collections      Collection[]
  environments     Environment[]
  userEnvironments UserEnvironment[]
  members          WorkspaceMember[]
  owner            User              @relation(fields: [ownerId], references: [id])
  workflows        Workflow[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now()) @map("joined_at")
  user        User          @relation(fields: [userId], references: [id])
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Collection {
  id          String              @id @default(uuid())
  workspaceId String              @map("workspace_id")
  name        String
  parentId    String?             @map("parent_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")
  parent      Collection?         @relation("SubCollections", fields: [parentId], references: [id])
  children    Collection[]        @relation("SubCollections")
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  requests    RequestDefinition[]

  @@map("collections")
}

model RequestDefinition {
  id           String     @id @default(uuid())
  collectionId String     @map("collection_id")
  name         String
  method       String
  url          String
  headers      Json?
  body         Json?
  params       Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  collection   Collection @relation(fields: [collectionId], references: [id])

  @@map("request_definitions")
}

model Environment {
  id               String                @id @default(uuid())
  workspaceId      String                @map("workspace_id")
  name             String
  isPersistent     Boolean               @default(false) @map("is_persistent")
  createdById      String                @map("created_by")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  deletedAt        DateTime?             @map("deleted_at")
  variables        EnvironmentVariable[]
  createdBy        User                  @relation(fields: [createdById], references: [id])
  workspace        Workspace             @relation(fields: [workspaceId], references: [id])
  userEnvironments UserEnvironment[]

  @@map("environments")
}

model UserEnvironment {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  workspaceId   String      @map("workspace_id")
  environmentId String      @map("environment_id")
  environment   Environment @relation(fields: [environmentId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])

  @@unique([userId, environmentId])
  @@map("user_environments")
}

model EnvironmentVariable {
  id            String      @id @default(uuid())
  environmentId String      @map("environment_id")
  key           String
  value         String
  isSecret      Boolean     @default(false) @map("is_secret")
  createdById   String      @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  createdBy     User        @relation(fields: [createdById], references: [id])
  environment   Environment @relation(fields: [environmentId], references: [id])

  @@unique([environmentId, key])
  @@map("environment_variables")
}

model Workflow {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  
  // JSON Structure:
  // [
  //   { "requestId": "uuid", "name": "Login", "stopOnFailure": true },
  //   { "requestId": "uuid", "name": "Get Profile" }
  // ]
  steps       Json     

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@map("workflows")
}
